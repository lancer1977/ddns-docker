CF_ZONE_NAME="example.com"
CF_CANONICAL_LABEL="home"
CF_CNAME_LABELS="dashy,api,identity"

CF_ENABLE_IPV4="true"
CF_ENABLE_IPV6="false"
CF_PROXIED="true"
CF_TTL="1"

SLEEP_SECONDS="300"
RUN_ON_STARTUP="true"
HEALTH_MAX_AGE_SECONDS="1800"

# Secrets (prefer *_FILE in Docker/Swarm)
CF_API_TOKEN_FILE="/run/secrets/cf_api_token"
CF_ZONE_ID_FILE="/run/secrets/cf_zone_id"
